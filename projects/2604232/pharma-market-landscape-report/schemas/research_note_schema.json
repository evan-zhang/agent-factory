{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Pharma Market Landscape Chapter Research Note",
  "type": "object",
  "required": [
    "metadata",
    "chapter_id",
    "chapter_title",
    "key_findings",
    "tables",
    "callout_candidates",
    "references"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["market", "product", "therapy_area", "research_date"],
      "properties": {
        "market": {"type": "string", "description": "目标市场，如：香港、台湾、新加坡"},
        "product": {"type": "string", "description": "产品名称，含品牌名+通用名"},
        "therapy_area": {"type": "string", "description": "治疗领域，如：皮肤科、肾脏科"},
        "research_date": {"type": "string", "description": "调研日期，ISO 8601 格式：YYYY-MM-DD"},
        "language": {"type": "string", "description": "输出语言，如：zh-CN、zh-TW、en"}
      }
    },
    "chapter_id": {
      "type": "string",
      "description": "章节编号，格式：ch01 ~ ch15（零填充两位数）"
    },
    "chapter_title": {
      "type": "string"
    },
    "key_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "source_type", "source_url"],
        "properties": {
          "claim": {"type": "string"},
          "source_type": {
            "type": "string",
            "enum": ["government", "regulator", "guideline", "journal", "hospital", "society", "company", "media", "database", "other"]
          },
          "source_url": {"type": "string"},
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          }
        }
      }
    },
    "tables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "columns", "rows"],
        "properties": {
          "title": {"type": "string"},
          "columns": {"type": "array", "items": {"type": "string"}},
          "rows": {"type": "array", "items": {"type": "array", "items": {"type": "string"}}}
        }
      }
    },
    "callout_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "text"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["highlight-box", "insight", "action-box"]
          },
          "text": {"type": "string"}
        }
      }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "url"],
        "properties": {
          "id": {"type": "string"},
          "label": {"type": "string"},
          "url": {"type": "string"}
        }
      }
    },
    "data_gaps": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
