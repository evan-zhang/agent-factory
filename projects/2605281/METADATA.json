{
  "name": "bd-eval-cms",
  "version": "0.1.0",
  "displayName": "CMS投前评估流水线",
  "description": "CMS（康哲药业）投前评估体系 — 基于19个技能 + 6-Gate门控的完整BD评估流水线",
  "author": "evan",
  "license": "private",
  "triggers": [
    "CMS投前评估",
    "CMS评估",
    "投前评估"
  ],
  "openclaw": {
    "minVersion": ">=0.9.0"
  },
  "requiredTools": [
    "web_search",
    "sessions_spawn",
    "exec",
    "message"
