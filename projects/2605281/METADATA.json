    "doc-viewer": {
      "path": "dependencies/doc-viewer",
      "role": "main",
      "required": true,
      "description": "生成HTML报告（Phase 5.5 必须）"
    },
    "multi-search": {
      "path": "dependencies/multi-search",
      "role": "main",
      "required": true,
      "description": "多源搜索基础设施"
    }
  },
  "installation": {
    "method": "copy",
    "target": "~/.openclaw/skills/",
    "skipExisting": true
  }
}
